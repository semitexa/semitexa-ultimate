<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Semitexa — {{ trans('hello.title') }} {{ trans('hello.greeting') }}</title>
    {{ asset_head() }}
</head>
<body class="theme-{{ accentColor }}">
    <div class="card">

        <div class="logo">
            <div class="logo-icon">⬡</div>
            <div class="logo-text">Semi<span>texa</span></div>
        </div>

        <h1>{{ trans('hello.title') }}<br><em>{{ trans('hello.greeting') }}</em></h1>

        <p class="subtitle">
            {{ trans('hello.subtitle') }}<br>
            {{ trans('hello.subtitle2')|raw }}
        </p>

        <div class="badges">
            <span class="badge"><span class="dot"></span>PHP {{ phpVersion }}</span>
            <span class="badge"><span class="dot"></span>Swoole {{ swooleVersion }}</span>
            <span class="badge"><span class="dot"></span>{{ trans('hello.badge.twig_ready') }}</span>
        </div>

        <div class="lang-switcher">
            <a class="lang-btn{{ lang == 'en' ? ' active' : '' }}" href="/?color={{ accentColor }}&lang=en">EN</a>
            <a class="lang-btn{{ lang == 'uk' ? ' active' : '' }}" href="/?color={{ accentColor }}&lang=uk">UK</a>
        </div>

        <div class="color-picker">
            <a class="color-swatch color-swatch--indigo{{ accentColor == 'indigo' ? ' active' : '' }}" data-color="indigo" href="/?color=indigo&lang={{ lang }}"></a>
            <a class="color-swatch color-swatch--emerald{{ accentColor == 'emerald' ? ' active' : '' }}" data-color="emerald" href="/?color=emerald&lang={{ lang }}"></a>
            <a class="color-swatch color-swatch--rose{{ accentColor == 'rose' ? ' active' : '' }}" data-color="rose" href="/?color=rose&lang={{ lang }}"></a>
            <a class="color-swatch color-swatch--amber{{ accentColor == 'amber' ? ' active' : '' }}" data-color="amber" href="/?color=amber&lang={{ lang }}"></a>
            <a class="color-swatch color-swatch--cyan{{ accentColor == 'cyan' ? ' active' : '' }}" data-color="cyan" href="/?color=cyan&lang={{ lang }}"></a>
        </div>

        <hr class="divider">

        <ul class="steps">
            <li>
                <span class="num">1</span>
                <span>{{ trans('hello.step1')|raw }}</span>
            </li>
            <li>
                <span class="num">2</span>
                <span>{{ trans('hello.step2')|raw }}</span>
            </li>
            <li>
                <span class="num">3</span>
                <span>{{ trans('hello.step3')|raw }}</span>
            </li>
        </ul>

        <p class="footer">
            <a href="https://semitexa.com/docs" target="_blank">{{ trans('hello.docs') }}</a> ·
            {{ trans('hello.footer') }}
        </p>

    </div>
    {{ asset_body() }}
</body>
</html>
