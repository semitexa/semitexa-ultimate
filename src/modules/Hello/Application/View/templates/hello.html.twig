<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Semitexa — Hello</title>
    {{ asset_head() }}
</head>
<body class="theme-{{ accentColor }}">
    <div class="card">

        <div class="logo">
            <div class="logo-icon">⬡</div>
            <div class="logo-text">Semi<span>texa</span></div>
        </div>

        <h1>Hello,<br><em>World!</em></h1>

        <p class="subtitle">
            Your Semitexa project is up and running.<br>
            This page is rendered by a <strong>Payload → Handler → Resource → Twig</strong> pipeline.
        </p>

        <div class="badges">
            <span class="badge"><span class="dot"></span>PHP {{ phpVersion }}</span>
            <span class="badge"><span class="dot"></span>Swoole {{ swooleVersion }}</span>
            <span class="badge"><span class="dot"></span>Twig ready</span>
        </div>

        <div class="color-picker">
            <a class="color-swatch color-swatch--indigo{{ accentColor == 'indigo' ? ' active' : '' }}" data-color="indigo" href="/?color=indigo"></a>
            <a class="color-swatch color-swatch--emerald{{ accentColor == 'emerald' ? ' active' : '' }}" data-color="emerald" href="/?color=emerald"></a>
            <a class="color-swatch color-swatch--rose{{ accentColor == 'rose' ? ' active' : '' }}" data-color="rose" href="/?color=rose"></a>
            <a class="color-swatch color-swatch--amber{{ accentColor == 'amber' ? ' active' : '' }}" data-color="amber" href="/?color=amber"></a>
            <a class="color-swatch color-swatch--cyan{{ accentColor == 'cyan' ? ' active' : '' }}" data-color="cyan" href="/?color=cyan"></a>
        </div>

        <hr class="divider">

        <ul class="steps">
            <li>
                <span class="num">1</span>
                <span>Run migrations: <code>./bin/semitexa db:migrate</code></span>
            </li>
            <li>
                <span class="num">2</span>
                <span>Add a local domain: <code>./bin/semitexa dns:add myapp.test</code></span>
            </li>
            <li>
                <span class="num">3</span>
                <span>Create your first module inside <code>src/modules/</code></span>
            </li>
        </ul>

        <p class="footer">
            <a href="https://semitexa.com/docs" target="_blank">Documentation</a> ·
            Semitexa Ultimate
        </p>

    </div>
    {{ asset_body() }}
</body>
</html>
