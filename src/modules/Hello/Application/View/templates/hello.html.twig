<!DOCTYPE html>
<html lang="{{ locale()|default('en')|e('html_attr') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Semitexa — {{ trans('hello.headline') }}</title>
    {% include '@project-layouts-theme-base/partials/head/theme-switcher.html.twig' %}
    {{ __ssr_preload_hints|default('')|raw }}
    {{ asset_head() }}
</head>
<body
    class="hello-page"
    data-theme-label-dark="{{ trans('hello.dark_mode') }}"
    data-theme-label-light="{{ trans('hello.light_mode') }}"
    {{ __ssr_handle_attr|default('')|raw }}
>
    <div class="hello-page__glow hello-page__glow--north"></div>
    <div class="hello-page__glow hello-page__glow--east"></div>

    <main class="hello-shell">
        <section class="hello-surface hello-surface--hero">
            <header class="hello-topbar">
                <div class="logo-lockup logo-lockup--meta" data-logo-lockup>
                    <div class="logo-mark" aria-hidden="true">
                        <span class="logo-mark__beam logo-mark__beam--north"></span>
                        <span class="logo-mark__beam logo-mark__beam--east"></span>
                        <span class="logo-mark__beam logo-mark__beam--south"></span>
                        <span class="logo-mark__beam logo-mark__beam--west"></span>
                        <span class="logo-mark__core"></span>
                    </div>

                    <div class="logo-wordmark" aria-label="Semitexa">
                        <span class="logo-wordmark__full">{{ trans('hello.brand_full') }}<span>{{ trans('hello.brand_accent') }}</span></span>
                    </div>
                </div>

                <div class="hello-topbar__actions">
                    <span class="hello-badge{{ demoInstalledLocally ? ' hello-badge--online' : '' }}">
                        {{ demoInstalledLocally ? trans('hello.demo_local') : trans('hello.demo_remote') }}
                    </span>

                    <div class="hello-theme-switch">
                        <span class="hello-theme-switch__text" aria-hidden="true" data-skin-text>{{ trans('hello.dark_mode') }}</span>
                        <button
                            class="hello-theme-switch__toggle"
                            type="button"
                            aria-label="{{ trans('hello.toggle_theme') }}"
                            aria-pressed="false"
                            data-skin-toggle
                        >
                            <span class="hello-theme-switch__track" aria-hidden="true">
                                <span class="hello-theme-switch__thumb"></span>
                            </span>
                        </button>
                    </div>

                </div>
            </header>

            <div class="hello-hero">
                <div class="hello-hero__copy">
                    <p class="hello-hero__eyebrow">{{ trans('hello.eyebrow') }}</p>
                    <h1>{{ trans('hello.headline') }}</h1>

                    <p class="hello-hero__lede">
                        {{ trans('hello.lede') }}
                    </p>

                    <div class="signal-strip">
                        <span class="signal-chip"><span class="signal-chip__dot"></span>PHP {{ phpVersion }}</span>
                        <span class="signal-chip"><span class="signal-chip__dot"></span>Swoole {{ swooleVersion }}</span>
                        <span class="signal-chip"><span class="signal-chip__dot"></span>{{ trans('hello.badge.architecture') }}</span>
                        <span class="signal-chip"><span class="signal-chip__dot"></span>{{ trans('hello.badge.ssr') }}</span>
                    </div>

                    <div class="cta-row">
                        <a class="cta cta--primary" href="https://semitexa.com/" target="_blank" rel="noopener noreferrer">{{ trans('hello.visit_site') }}</a>
                        <a class="cta cta--ghost" href="https://framework.semitexa.com/" target="_blank" rel="noopener noreferrer">{{ trans('hello.docs') }}</a>
                        <a
                            class="cta cta--soft"
                            href="{{ demoUrl }}"
                            {% if demoUrlIsExternal %}target="_blank" rel="noopener noreferrer"{% endif %}
                        >{{ trans('hello.learn_more') }}</a>
                    </div>
                </div>

                <aside class="hello-surface hello-surface--aside">
                    <p class="hello-panel__eyebrow">{{ trans('hello.guide_eyebrow') }}</p>
                    <h2>{{ trans('hello.guide_title') }}</h2>
                    <p class="hello-panel__body">{{ trans('hello.guide_body') }}</p>

                    <div class="hello-panel__grid">
                        <div class="hello-panel__metric">
                            <span class="hello-panel__metric-label">{{ trans('hello.metric.module') }}</span>
                            <code>src/modules/Hello</code>
                        </div>
                        <div class="hello-panel__metric">
                            <span class="hello-panel__metric-label">{{ trans('hello.metric.demo') }}</span>
                            <span>{{ demoInstalledLocally ? trans('hello.metric.demo_local') : trans('hello.metric.demo_remote') }}</span>
                        </div>
                    </div>

                    <p class="hello-panel__hint">
                        {{ demoInstalledLocally ? trans('hello.demo_hint_local') : trans('hello.demo_hint_remote') }}
                    </p>
                </aside>
            </div>
        </section>

        <section class="hello-surface hello-surface--guides">
            <div class="guides-intro">
                <p class="guides-intro__eyebrow">{{ trans('hello.deferred_eyebrow') }}</p>
                <p class="guides-intro__body">{{ trans('hello.deferred_body') }}</p>
            </div>

            <div class="guides">
                {{ layout_slot_deferred('guide_01') }}
                {{ layout_slot_deferred('guide_02') }}
                {{ layout_slot_deferred('guide_03') }}
            </div>
        </section>

        <footer class="hello-footer">
            <span>{{ trans('hello.footer') }}</span>
        </footer>
    </main>

    {{ __ssr_deferred_manifest|default('')|raw }}
    {{ __ssr_runtime_script|default('')|raw }}
    <script src="/assets/Hello/js/hello.js" defer></script>
    {{ asset_body() }}
</body>
</html>
