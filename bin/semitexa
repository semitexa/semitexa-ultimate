#!/bin/sh
# ─────────────────────────────────────────────────────────────────────────────
# Semitexa CLI — universal entry point (POSIX shell, no PHP required on host)
#
# Usage:  bin/semitexa <command> [arguments...]
#
# Server lifecycle commands (server:start, server:stop, server:restart) are
# handled natively in this shell script via Docker Compose.
#
# Local routing commands (local-router:* and local-domain:*) manage the shared
# Semitexa workstation router for .test domains.
#
# All other commands are proxied into the running "app" container so PHP
# execution always uses the exact same runtime that powers the framework.
#
# Compatible with: macOS, Linux, Windows (Git Bash / WSL / MSYS2)
# Architecture:    AMD64 and ARM64 (Apple Silicon, Raspberry Pi, etc.)
# ─────────────────────────────────────────────────────────────────────────────
set -e

# ── Resolve project root (follow symlinks, works on macOS + Linux) ──────────
resolve_script_dir() {
    _source="$0"
    while [ -L "$_source" ]; do
        _dir="$(cd -P "$(dirname "$_source")" && pwd)"
        _source="$(readlink "$_source")"
        case "$_source" in
            /*) ;;
            *)  _source="$_dir/$_source" ;;
        esac
    done
    cd -P "$(dirname "$_source")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_ROOT" || {
    printf '[ERROR] Failed to enter project root: %s\n' "$PROJECT_ROOT" >&2
    exit 1
}

# ── Colour helpers (safe for non-tty / Windows) ────────────────────────────
if [ -t 1 ] && command -v tput >/dev/null 2>&1; then
    C_RESET="$(tput sgr0 2>/dev/null || true)"
    C_GREEN="$(tput setaf 2 2>/dev/null || true)"
    C_YELLOW="$(tput setaf 3 2>/dev/null || true)"
    C_RED="$(tput setaf 1 2>/dev/null || true)"
    C_CYAN="$(tput setaf 6 2>/dev/null || true)"
    C_BOLD="$(tput bold 2>/dev/null || true)"
else
    C_RESET="" C_GREEN="" C_YELLOW="" C_RED="" C_CYAN="" C_BOLD=""
fi

info()    { printf "%s[INFO]%s  %s\n"    "$C_CYAN"   "$C_RESET" "$*"; }
success() { printf "%s[OK]%s    %s\n"    "$C_GREEN"  "$C_RESET" "$*"; }
warn()    { printf "%s[WARN]%s  %s\n"    "$C_YELLOW" "$C_RESET" "$*" >&2; }
error()   { printf "%s[ERROR]%s %s\n"    "$C_RED"    "$C_RESET" "$*" >&2; }

# ── Env readers (.env.default + .env.local, legacy .env compatibility) ─────
env_existing_files_low_to_high() {
    for _file in \
        "$PROJECT_ROOT/.env.default" \
        "$PROJECT_ROOT/.env" \
        "$PROJECT_ROOT/.env.local"
    do
        [ -f "$_file" ] && printf '%s\n' "$_file"
    done
}

env_runtime_file_exists() {
    for _file in "$PROJECT_ROOT/.env.default" "$PROJECT_ROOT/.env" "$PROJECT_ROOT/.env.local"; do
        [ -f "$_file" ] && return 0
    done
    return 1
}

env_merged_lines() {
    _files="$(env_existing_files_low_to_high | tr '\n' ' ')"
    [ -n "$_files" ] || return 0

    # shellcheck disable=SC2086
    awk '
        /^[[:space:]]*#/ || /^[[:space:]]*$/ || index($0, "=") == 0 { next }
        {
            line = $0
            sub(/\r$/, "", line)
            key = line
            sub(/[[:space:]]*=.*$/, "", key)
            gsub(/[[:space:]]/, "", key)
            if (key !~ /^[A-Za-z_][A-Za-z0-9_]*$/) {
                next
            }
            values[key] = line
            if (!(key in first_seen)) {
                order[++count] = key
                first_seen[key] = 1
            }
        }
        END {
            for (i = 1; i <= count; i++) {
                key = order[i]
                if (!(key in printed) && (key in values)) {
                    print values[key]
                    printed[key] = 1
                }
            }
        }
    ' $_files
}

env_val() {
    _key="$1"
    _default="$2"
    _val="$(env_merged_lines 2>/dev/null | grep -E "^[[:space:]]*${_key}[[:space:]]*=" 2>/dev/null | head -1 | sed 's/^[^=]*=[[:space:]]*//' | sed 's/[[:space:]]*$//' | sed 's/^"//' | sed 's/"$//')"
    if [ -n "$_val" ]; then
        printf '%s' "$_val"
        return
    fi
    printf '%s' "$_default"
}

env_export_compose_context() {
    _merged="$(env_merged_lines || true)"
    [ -n "$_merged" ] || return 0

    _old_ifs=$IFS
    IFS='
'
    for _line in $_merged; do
        [ -n "$_line" ] || continue
        _key="$(printf '%s' "$_line" | sed 's/[[:space:]]*=.*$//' | tr -d '[:space:]')"
        _val="$(printf '%s' "$_line" | sed 's/^[^=]*=[[:space:]]*//' | sed 's/[[:space:]]*$//' | sed 's/^"//' | sed 's/"$//')"
        case "$_key" in
            ''|*[!A-Za-z0-9_]*)
                continue
                ;;
        esac
        export "$_key=$_val"
    done
    IFS=$_old_ifs
}

# ── Docker Compose helpers ──────────────────────────────────────────────────
has_compose() {
    docker compose version >/dev/null 2>&1 && return 0
    docker-compose version >/dev/null 2>&1 && return 0
    return 1
}

compose_bin() {
    if docker compose version >/dev/null 2>&1; then
        echo "docker compose"
    elif docker-compose version >/dev/null 2>&1; then
        echo "docker-compose"
    else
        error "Docker Compose not found. Install Docker Desktop or docker-compose."
        exit 1
    fi
}

compose_args() {
    _args="-f docker-compose.yml"
    _has_overlay=0

    if [ -f "$PROJECT_ROOT/docker-compose.rabbitmq.yml" ]; then
        _async="$(env_val EVENTS_ASYNC 0)"
        case "$_async" in 1|true|yes) _args="$_args -f docker-compose.rabbitmq.yml"; _has_overlay=1 ;; esac
    fi
    if [ -f "$PROJECT_ROOT/docker-compose.mysql.yml" ]; then
        _db="$(env_val DB_DRIVER "")"
        if [ -n "$_db" ]; then _args="$_args -f docker-compose.mysql.yml"; _has_overlay=1; fi
    fi
    if [ -f "$PROJECT_ROOT/docker-compose.redis.yml" ]; then
        _redis="$(env_val REDIS_HOST "")"
        if [ -n "$_redis" ]; then _args="$_args -f docker-compose.redis.yml"; _has_overlay=1; fi
    fi
    if [ -f "$PROJECT_ROOT/docker-compose.ollama.yml" ]; then
        _llm_provider="$(env_val LLM_PROVIDER "")"
        if [ "$_llm_provider" = "ollama" ]; then _args="$_args -f docker-compose.ollama.yml"; _has_overlay=1; fi
    fi
    if [ "$_has_overlay" -eq 0 ]; then
        echo ""
    else
        echo "$_args"
    fi
}

run_compose() {
    _compose="$(compose_bin)"
    _overlays="$(compose_args)"
    (
        env_export_compose_context
        if [ -n "$_overlays" ]; then
            # shellcheck disable=SC2086
            $_compose $_overlays "$@"
        else
            $_compose "$@"
        fi
    )
}

is_app_running() {
    _compose="$(compose_bin)"
    _overlays="$(compose_args)"
    _status="$(
        env_export_compose_context
        if [ -n "$_overlays" ]; then
            # shellcheck disable=SC2086
            $_compose $_overlays ps --format '{{.State}}' app 2>/dev/null || true
        else
            $_compose ps --format '{{.State}}' app 2>/dev/null || true
        fi
    )"
    case "$_status" in
        *running*) return 0 ;;
        *)         return 1 ;;
    esac
}

wait_for_service() {
    _service_name="$1" _host="$2" _port="$3" _max_attempts="$4" _delay="$5" _initial_wait="${6:-0}"

    if [ "$_initial_wait" -gt 0 ]; then
        info "Waiting ${_initial_wait}s for $_service_name to initialise..."
        sleep "$_initial_wait"
    fi

    _attempt=1
    while [ "$_attempt" -le "$_max_attempts" ]; do
        if run_compose exec -T app sh -c "
            (echo > /dev/tcp/$_host/$_port) 2>/dev/null ||
            nc -z $_host $_port 2>/dev/null ||
            timeout 3 sh -c \"cat < /dev/null > /dev/tcp/$_host/$_port\" 2>/dev/null
        " >/dev/null 2>&1; then
            success "$_service_name: reachable"
            return 0
        fi
        _attempt=$((_attempt + 1))
        [ "$_attempt" -le "$_max_attempts" ] && sleep "$_delay"
    done

    warn "$_service_name: not reachable after $_max_attempts attempts (may still be starting)"
    return 1
}

# ── Shared local router helpers ─────────────────────────────────────────────
SEMITEXA_HOME="${SEMITEXA_HOME:-$HOME/.semitexa}"
ROUTER_ROOT="$SEMITEXA_HOME/router"
ROUTER_COMPOSE="$ROUTER_ROOT/docker-compose.yml"
ROUTER_MODE_FILE="$ROUTER_ROOT/mode"
ROUTER_REGISTRY_DIR="$ROUTER_ROOT/registry/domains"
ROUTER_NGINX_DIR="$ROUTER_ROOT/nginx/generated"
ROUTER_DNS_DIR="$ROUTER_ROOT/dns/generated"
ROUTER_NGINX_DEFAULT="$ROUTER_NGINX_DIR/default.conf"
ROUTER_NGINX_DOMAINS="$ROUTER_NGINX_DIR/domains.conf"
ROUTER_DNSMASQ_CONF="$ROUTER_DNS_DIR/dnsmasq.conf"
ROUTER_DNS_DOMAINS="$ROUTER_DNS_DIR/domains.conf"

router_ensure_dirs() {
    mkdir -p "$ROUTER_ROOT" "$ROUTER_REGISTRY_DIR" "$ROUTER_NGINX_DIR" "$ROUTER_DNS_DIR"
}

router_entry_key() {
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9.-' '_'
}

router_entry_path() {
    printf '%s/%s.env' "$ROUTER_REGISTRY_DIR" "$(router_entry_key "$1")"
}

router_mode_get() {
    if [ -f "$ROUTER_MODE_FILE" ]; then
        _mode="$(tr -d '[:space:]' < "$ROUTER_MODE_FILE" 2>/dev/null || true)"
        case "$_mode" in dns|hosts) printf '%s' "$_mode"; return ;; esac
    fi
    printf 'dns'
}

router_mode_set() {
    _mode="$1"
    case "$_mode" in
        dns|hosts) ;;
        *)
            error "Unsupported local router mode: $_mode"
            exit 1
            ;;
    esac
    router_ensure_dirs
    printf '%s\n' "$_mode" > "$ROUTER_MODE_FILE"
}

router_validate_domain() {
    _domain="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
    case "$_domain" in
        *.test) ;;
        *) return 1 ;;
    esac
    _label="${_domain%.test}"
    [ -n "$_label" ] || return 1
    case "$_label" in
        *[!a-z0-9.-]*|-*|*-) return 1 ;;
    esac
    return 0
}

router_registry_write_entry() {
    _domain="$1"
    _upstream_port="$2"
    _mode="$3"
    _path="$(router_entry_path "$_domain")"
    _compose_project_name="$(basename "$PROJECT_ROOT")"

    router_ensure_dirs
    cat > "$_path" <<EOF
DOMAIN=$_domain
PROJECT_ROOT=$PROJECT_ROOT
COMPOSE_PROJECT_NAME=$_compose_project_name
UPSTREAM_HOST=host.docker.internal
UPSTREAM_PORT=$_upstream_port
MODE=$_mode
UPDATED_AT=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
EOF
}

router_registry_delete_entry() {
    _domain="$1"
    rm -f "$(router_entry_path "$_domain")"
}

router_registry_count() {
    find "$ROUTER_REGISTRY_DIR" -maxdepth 1 -type f -name '*.env' 2>/dev/null | wc -l | tr -d ' '
}

router_collect_project_domains() {
    env_merged_lines 2>/dev/null \
        | grep -E '^[[:space:]]*[A-Z0-9_]*DOMAIN[A-Z0-9_]*[[:space:]]*=' 2>/dev/null \
        | while IFS= read -r _line; do
            _value="$(printf '%s' "$_line" | sed 's/^[^=]*=[[:space:]]*//' | sed 's/[[:space:]]*$//' | sed 's/^"//' | sed 's/"$//')"
            printf '%s\n' "$_value" | tr ', ' '\n\n' | while IFS= read -r _candidate; do
                _candidate="$(printf '%s' "$_candidate" | tr '[:upper:]' '[:lower:]')"
                [ -n "$_candidate" ] || continue
                if router_validate_domain "$_candidate"; then
                    printf '%s\n' "$_candidate"
                fi
            done
        done | sort -u
}

router_sync_project_domains() {
    _domains="$(router_collect_project_domains || true)"
    [ -n "$_domains" ] || return 0

    _saved_project_root="$PROJECT_ROOT"
    _port="$(env_val SWOOLE_PORT 8080)"
    _mode="$(router_mode_get)"

    router_ensure_dirs

    for _entry in "$ROUTER_REGISTRY_DIR"/*.env; do
        [ -f "$_entry" ] || continue
        DOMAIN='' PROJECT_ROOT='' UPSTREAM_PORT='' MODE=''
        # shellcheck disable=SC1090
        . "$_entry"
        [ "$PROJECT_ROOT" = "$_saved_project_root" ] || continue
        if ! printf '%s\n' "$_domains" | grep -Fx -- "$DOMAIN" >/dev/null 2>&1; then
            rm -f "$_entry"
        fi
    done

    PROJECT_ROOT="$_saved_project_root"
    printf '%s\n' "$_domains" | while IFS= read -r _domain; do
        [ -n "$_domain" ] || continue
        router_registry_write_entry "$_domain" "$_port" "$_mode"
    done
    PROJECT_ROOT="$_saved_project_root"
}

router_project_domain_count() {
    _project_root="${1:-$PROJECT_ROOT}"
    _saved_project_root="$PROJECT_ROOT"
    _count=0
    for _entry in "$ROUTER_REGISTRY_DIR"/*.env; do
        [ -f "$_entry" ] || continue
        DOMAIN='' PROJECT_ROOT='' UPSTREAM_PORT='' MODE=''
        # shellcheck disable=SC1090
        . "$_entry"
        [ "$PROJECT_ROOT" = "$_project_root" ] || continue
        _count=$((_count + 1))
    done
    PROJECT_ROOT="$_saved_project_root"
    printf '%s' "$_count"
}

project_has_shared_domains() {
    [ "$(router_project_domain_count "$PROJECT_ROOT")" -gt 0 ] && return 0
    [ -n "$(router_collect_project_domains || true)" ]
}

router_generate_nginx_config() {
    router_ensure_dirs
    _saved_project_root="$PROJECT_ROOT"
    cat > "$ROUTER_NGINX_DEFAULT" <<'EOF'
server {
    listen 80 default_server;
    server_name _;

    default_type text/plain;

    location / {
        return 404 "Semitexa local router: domain is not registered or its upstream is unavailable.\n";
    }
}
EOF

    : > "$ROUTER_NGINX_DOMAINS"
    for _entry in "$ROUTER_REGISTRY_DIR"/*.env; do
        [ -f "$_entry" ] || continue
        DOMAIN='' PROJECT_ROOT='' COMPOSE_PROJECT_NAME='' UPSTREAM_HOST='' UPSTREAM_PORT='' MODE='' UPDATED_AT=''
        # shellcheck disable=SC1090
        . "$_entry"
        [ -n "$DOMAIN" ] || continue
        [ -n "$UPSTREAM_PORT" ] || continue
        cat >> "$ROUTER_NGINX_DOMAINS" <<EOF
server {
    listen 80;
    server_name $DOMAIN;

    location / {
        proxy_pass http://$UPSTREAM_HOST:$UPSTREAM_PORT;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }
}

EOF
    done
    PROJECT_ROOT="$_saved_project_root"
}

router_generate_dns_config() {
    router_ensure_dirs
    _saved_project_root="$PROJECT_ROOT"
    cat > "$ROUTER_DNSMASQ_CONF" <<'EOF'
port=53
no-resolv
no-daemon
log-queries
conf-file=/etc/dnsmasq.d/domains.conf
EOF

    : > "$ROUTER_DNS_DOMAINS"
    for _entry in "$ROUTER_REGISTRY_DIR"/*.env; do
        [ -f "$_entry" ] || continue
        DOMAIN='' MODE=''
        # shellcheck disable=SC1090
        . "$_entry"
        [ -n "$DOMAIN" ] || continue
        printf 'address=/%s/127.0.0.1\n' "$DOMAIN" >> "$ROUTER_DNS_DOMAINS"
    done
    PROJECT_ROOT="$_saved_project_root"
}

router_generate_compose() {
    router_ensure_dirs
    cat > "$ROUTER_COMPOSE" <<EOF
services:
  dns:
    image: alpine:3.21
    container_name: semitexa-router-dns
    restart: unless-stopped
    command: ["sh", "-c", "apk add --no-cache dnsmasq && dnsmasq --keep-in-foreground --conf-file=/etc/dnsmasq.d/dnsmasq.conf"]
    ports:
      - "127.0.0.1:5553:53/udp"
      - "127.0.0.1:5553:53/tcp"
    volumes:
      - $ROUTER_DNSMASQ_CONF:/etc/dnsmasq.d/dnsmasq.conf:ro
      - $ROUTER_DNS_DOMAINS:/etc/dnsmasq.d/domains.conf:ro
    cap_add:
      - NET_ADMIN
    healthcheck:
      test: ["CMD", "nslookup", "localhost", "127.0.0.1"]
      interval: 10s
      timeout: 3s
      retries: 3
      start_period: 5s

  proxy:
    image: nginx:alpine
    container_name: semitexa-router-proxy
    restart: unless-stopped
    ports:
      - "80:80"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - $ROUTER_NGINX_DEFAULT:/etc/nginx/conf.d/default.conf:ro
      - $ROUTER_NGINX_DOMAINS:/etc/nginx/conf.d/semitexa-domains.conf:ro
EOF
}

router_render() {
    router_generate_compose
    router_generate_nginx_config
    router_generate_dns_config
}

router_compose() {
    _compose="$(compose_bin)"
    $_compose -f "$ROUTER_COMPOSE" "$@"
}

tty_available() {
    [ -t 0 ] && [ -e /dev/tty ]
}

sudo_ready() {
    sudo -n true >/dev/null 2>&1
}

router_configure_resolved_for_test() {
    if ! command -v systemctl >/dev/null 2>&1 || ! systemctl is-active --quiet systemd-resolved; then
        return 0
    fi

    _needs_restart=0
    if grep -qi "^DNSStubListener=no" /etc/systemd/resolved.conf 2>/dev/null; then
        warn "systemd-resolved has DNSStubListener=no (breaks shared .test resolution)."
        if tty_available; then
            printf "%s? Do you want to fix this automatically? (requires sudo) [Y/n]%s " "$C_YELLOW" "$C_RESET"
            read -r _ans </dev/tty
        elif sudo_ready; then
            _ans="y"
        else
            warn "Skipping DNSStubListener fix (no TTY and sudo requires a password)."
            _ans="n"
        fi
        if [ "$_ans" != "n" ] && [ "$_ans" != "N" ]; then
            if sudo sed -i 's/^DNSStubListener=no/DNSStubListener=yes/i' /etc/systemd/resolved.conf; then
                success "Set DNSStubListener=yes"
                _needs_restart=1
            else
                warn "Failed to set DNSStubListener=yes."
            fi
        fi
    fi

    if [ ! -f /etc/systemd/resolved.conf.d/semitexa-router.conf ]; then
        info "Shared Semitexa router is not yet bound to .test."
        if tty_available; then
            printf "%s? Do you want to configure this automatically? (requires sudo) [Y/n]%s " "$C_YELLOW" "$C_RESET"
            read -r _ans </dev/tty
        elif sudo_ready; then
            _ans="y"
        else
            warn "Skipping automatic .test resolver setup (no TTY and sudo requires a password)."
            _ans="n"
        fi
        if [ "$_ans" != "n" ] && [ "$_ans" != "N" ]; then
            if sudo mkdir -p /etc/systemd/resolved.conf.d/ \
                && printf "[Resolve]\nDNS=127.0.0.1:5553\nDomains=~test\n" | sudo tee /etc/systemd/resolved.conf.d/semitexa-router.conf >/dev/null; then
                success "Created /etc/systemd/resolved.conf.d/semitexa-router.conf"
                _needs_restart=1
            else
                warn "Failed to create /etc/systemd/resolved.conf.d/semitexa-router.conf."
            fi
        fi
    fi

    if [ "$_needs_restart" -eq 1 ]; then
        info "Restarting systemd-resolved to apply shared .test routing..."
        if sudo systemctl restart systemd-resolved \
            && sudo ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf; then
            success "systemd-resolved restarted and configured!"
            echo ""
        else
            warn "Failed to restart systemd-resolved cleanly."
        fi
    fi
}

router_hosts_remove_domain() {
    _domain="$1"
    if ! grep -q "^[[:space:]]*127\\.0\\.0\\.1[[:space:]].*${_domain}.*# semitexa-router\$" /etc/hosts 2>/dev/null; then
        return 0
    fi
    _tmp="$(mktemp)"
    grep -v "^[[:space:]]*127\\.0\\.0\\.1[[:space:]].*${_domain}.*# semitexa-router\$" /etc/hosts > "$_tmp" 2>/dev/null || true
    sudo tee /etc/hosts >/dev/null < "$_tmp"
    rm -f "$_tmp"
}

router_hosts_ensure_domain() {
    _domain="$1"
    if grep -q "^[[:space:]]*127\\.0\\.0\\.1[[:space:]].*${_domain}.*# semitexa-router\$" /etc/hosts 2>/dev/null; then
        return 0
    fi
    printf '127.0.0.1 %s # semitexa-router\n' "$_domain" | sudo tee -a /etc/hosts >/dev/null
}

router_apply_name_resolution() {
    _mode="$(router_mode_get)"
    _domain="${1:-}"

    case "$_mode" in
        dns)
            router_configure_resolved_for_test
            [ -n "$_domain" ] && router_hosts_remove_domain "$_domain" >/dev/null 2>&1 || true
            ;;
        hosts)
            [ -n "$_domain" ] && router_hosts_ensure_domain "$_domain"
            ;;
    esac
}

router_start_for_mode() {
    _mode="$(router_mode_get)"
    router_render
    case "$_mode" in
        dns)
            router_apply_name_resolution
            router_compose up -d dns proxy
            router_compose restart dns proxy >/dev/null 2>&1 || true
            ;;
        hosts)
            router_compose up -d proxy
            router_compose stop dns >/dev/null 2>&1 || true
            router_compose restart proxy >/dev/null 2>&1 || true
            ;;
    esac
}

cmd_local_router_init() {
    printf "\n%s%s Semitexa — Shared Local Router Init %s\n\n" "$C_BOLD" "$C_CYAN" "$C_RESET"
    router_ensure_dirs
    router_mode_set "$(router_mode_get)"
    router_render
    success "Shared local router workspace prepared at $ROUTER_ROOT"
    info "Mode: $(router_mode_get)"
    printf "\n"
}

cmd_local_router_start() {
    printf "\n%s%s Semitexa — Shared Local Router Start %s\n\n" "$C_BOLD" "$C_CYAN" "$C_RESET"
    cmd_local_router_init >/dev/null
    router_start_for_mode
    success "Shared local router started."
    info "Mode: $(router_mode_get)"
    printf "\n"
}

cmd_local_router_stop() {
    printf "\n%s%s Semitexa — Shared Local Router Stop %s\n\n" "$C_BOLD" "$C_CYAN" "$C_RESET"
    if [ ! -f "$ROUTER_COMPOSE" ]; then
        info "Shared local router is not initialized."
        exit 0
    fi
    router_compose down
    success "Shared local router stopped."
    printf "\n"
}

cmd_local_router_restart() {
    printf "\n%s%s Semitexa — Shared Local Router Restart %s\n\n" "$C_BOLD" "$C_CYAN" "$C_RESET"
    cmd_local_router_init >/dev/null
    router_render
    _mode="$(router_mode_get)"
    case "$_mode" in
        dns)
            router_compose restart dns proxy
            ;;
        hosts)
            router_compose restart proxy
            ;;
    esac
    success "Shared local router restarted."
    printf "\n"
}

cmd_local_router_doctor() {
    printf "\n%s%s Semitexa — Shared Local Router Doctor %s\n\n" "$C_BOLD" "$C_CYAN" "$C_RESET"
    if [ ! -d "$ROUTER_ROOT" ]; then
        warn "Shared local router workspace does not exist."
        info "Run: bin/semitexa local-router:init"
        exit 1
    fi

    info "Root: $ROUTER_ROOT"
    info "Mode: $(router_mode_get)"
    info "Registered domains: $(router_registry_count)"

    if [ -f "$ROUTER_COMPOSE" ]; then
        printf "\n"
        router_compose ps || true
    fi

    printf "\n"
    cmd_local_domain_list
}

cmd_local_domain_mode() {
    _mode="${1:-}"
    if [ -z "$_mode" ]; then
        printf "%s\n" "$(router_mode_get)"
        exit 0
    fi
    router_mode_set "$_mode"
    router_render
    success "Shared local router mode set to $_mode."
    case "$_mode" in
        dns)
            info "Restart the shared router to enable shared .test DNS."
            ;;
        hosts)
            info "Future domain registrations will write /etc/hosts entries."
            ;;
    esac
}

cmd_local_domain_add() {
    _domain="$(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]')"
    if [ -z "$_domain" ]; then
        error "Usage: bin/semitexa local-domain:add <domain.test>"
        exit 1
    fi
    if ! router_validate_domain "$_domain"; then
        error "Only valid .test domains are supported."
        exit 1
    fi

    _port="$(env_val SWOOLE_PORT 8080)"
    cmd_local_router_init >/dev/null
    router_registry_write_entry "$_domain" "$_port" "$(router_mode_get)"
    router_render
    router_apply_name_resolution "$_domain"
    if [ -f "$ROUTER_COMPOSE" ]; then
        router_start_for_mode
        if [ "$(router_mode_get)" = "dns" ]; then
            router_compose restart dns proxy >/dev/null 2>&1 || true
        else
            router_compose restart proxy >/dev/null 2>&1 || true
        fi
    fi

    success "Registered shared local domain: $_domain -> http://host.docker.internal:${_port}"
}

cmd_local_domain_remove() {
    _domain="$(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]')"
    if [ -z "$_domain" ]; then
        error "Usage: bin/semitexa local-domain:remove <domain.test>"
        exit 1
    fi
    _path="$(router_entry_path "$_domain")"
    if [ ! -f "$_path" ]; then
        warn "Domain '$_domain' is not registered in the shared router."
        exit 0
    fi

    router_registry_delete_entry "$_domain"
    router_render
    router_hosts_remove_domain "$_domain" >/dev/null 2>&1 || true
    if [ -f "$ROUTER_COMPOSE" ]; then
        if [ "$(router_mode_get)" = "dns" ]; then
            router_compose restart dns proxy >/dev/null 2>&1 || true
        else
            router_compose restart proxy >/dev/null 2>&1 || true
        fi
    fi

    success "Removed shared local domain: $_domain"
}

cmd_local_domain_list() {
    printf "\n%s%s Semitexa — Shared Local Domains %s\n\n" "$C_BOLD" "$C_CYAN" "$C_RESET"
    router_ensure_dirs
    _saved_project_root="$PROJECT_ROOT"
    _count=0
    for _entry in "$ROUTER_REGISTRY_DIR"/*.env; do
        [ -f "$_entry" ] || continue
        DOMAIN='' UPSTREAM_PORT='' PROJECT_ROOT='' MODE=''
        # shellcheck disable=SC1090
        . "$_entry"
        [ -n "$DOMAIN" ] || continue
        printf "  %s%-30s%s → host.docker.internal:%s [%s]\n" "$C_GREEN" "$DOMAIN" "$C_RESET" "$UPSTREAM_PORT" "$MODE"
        _count=$((_count + 1))
    done
    printf "\n"
    [ "$_count" -eq 0 ] && info "No shared local domains registered."
    [ "$_count" -gt 0 ] && info "$_count shared domain(s) configured."
    PROJECT_ROOT="$_saved_project_root"
    printf "\n"
}

# ═══════════════════════════════════════════════════════════════════════
#  server:start
# ═══════════════════════════════════════════════════════════════════════
cmd_server_start() {
    printf "\n%s%s Semitexa — Starting Environment %s\n\n" "$C_BOLD" "$C_CYAN" "$C_RESET"

    if [ ! -f "$PROJECT_ROOT/docker-compose.yml" ]; then
        error "docker-compose.yml not found."
        info  "Run: bin/semitexa init"
        exit 1
    fi

    _overlays="$(compose_args)"
    [ -n "$_overlays" ] && info "Compose files: $_overlays"

    # ── Pre-flight Checks (Proxy & DNS) ──────────────────────────────
    if project_has_shared_domains; then
        router_sync_project_domains
        if command -v ss >/dev/null 2>&1; then
            _port80_pid="$(ss -ltnp 2>/dev/null | awk '$4 ~ /:80$/ {print $6}' | sed -n 's/.*pid=\([0-9]*\).*/\1/p' | head -n 1)"
            if [ -n "$_port80_pid" ]; then
                _port80_proc="$(ps -p "$_port80_pid" -o comm= 2>/dev/null || echo "unknown")"
                if [ "$_port80_proc" != "docker-proxy" ] && [ "$_port80_proc" != "docker" ] && [ "$_port80_proc" != "dockerd" ]; then
                    warn "Port 80 is occupied by '$_port80_proc' (PID: $_port80_pid)."
                    warn "The shared Semitexa proxy will fail to start."
                    printf "%s? Do you want to stop it now? (requires sudo) [Y/n]%s " "$C_YELLOW" "$C_RESET"
                    read -r _ans </dev/tty
                    if [ "$_ans" != "n" ] && [ "$_ans" != "N" ]; then
                        sudo systemctl stop "$_port80_proc" 2>/dev/null || sudo kill -9 "$_port80_pid"
                        success "Attempted to stop $_port80_proc."
                    fi
                    echo ""
                fi
            fi
        fi

        info "Project uses shared local routing. Ensuring shared router is running..."
        if ! router_start_for_mode; then
            error "Failed to start the shared local router."
            info "Inspect it with: bin/semitexa local-router:doctor"
            exit 1
        fi
    fi

    info "Starting containers..."
    run_compose up -d --build

    _port="$(env_val SWOOLE_PORT 8080)"
    printf "\n"
    success "Semitexa environment started!"
    info "App:  ${C_GREEN}http://localhost:${_port}${C_RESET}"
    info "Logs: docker compose logs -f"
    info "Stop: bin/semitexa server:stop"

    _async="$(env_val EVENTS_ASYNC 0)"
    case "$_async" in
        1|true|yes)
            [ -f "$PROJECT_ROOT/docker-compose.rabbitmq.yml" ] && wait_for_service "RabbitMQ" "rabbitmq" "5672" 3 2 1 || true
            ;;
    esac

    _db="$(env_val DB_DRIVER "")"
    [ -n "$_db" ] && [ -f "$PROJECT_ROOT/docker-compose.mysql.yml" ] && wait_for_service "MySQL" "mysql" "3306" 5 4 20 || true

    _redis="$(env_val REDIS_HOST "")"
    [ -n "$_redis" ] && [ -f "$PROJECT_ROOT/docker-compose.redis.yml" ] && wait_for_service "Redis" "redis" "6379" 3 2 1 || true

    if project_has_shared_domains; then
        _count="$(router_project_domain_count "$PROJECT_ROOT")"
        [ "$_count" -gt 0 ] && info "Shared router: $_count local domain(s) configured (bin/semitexa local-domain:list)"
    fi

    printf "\n"
}

# ═══════════════════════════════════════════════════════════════════════
#  server:stop
# ═══════════════════════════════════════════════════════════════════════
cmd_server_stop() {
    printf "\n%s%s Semitexa — Stopping Environment %s\n\n" "$C_BOLD" "$C_CYAN" "$C_RESET"

    if [ ! -f "$PROJECT_ROOT/docker-compose.yml" ]; then
        warn "docker-compose.yml not found. Nothing to stop."
        exit 0
    fi

    info "Stopping containers..."
    run_compose down
    success "Semitexa environment stopped."

    for _pidfile in "$PROJECT_ROOT/var/swoole.pid" "$PROJECT_ROOT/var/run/semitexa.pid"; do
        if [ -f "$_pidfile" ]; then
            _pid="$(cat "$_pidfile" 2>/dev/null || true)"
            [ -n "$_pid" ] && kill "$_pid" 2>/dev/null || true
            rm -f "$_pidfile"
        fi
    done

    printf "\n"
}

# ═══════════════════════════════════════════════════════════════════════
#  server:restart
# ═══════════════════════════════════════════════════════════════════════
cmd_server_restart() {
    _service="${1:-}"
    printf "\n%s%s Semitexa — Restarting Environment %s\n\n" "$C_BOLD" "$C_CYAN" "$C_RESET"

    if [ ! -f "$PROJECT_ROOT/docker-compose.yml" ]; then
        error "docker-compose.yml not found."
        exit 1
    fi

    if [ -n "$_service" ]; then
        info "Restarting service: $_service"
        run_compose restart "$_service"
    else
        info "Restarting all containers..."
        run_compose restart
    fi

    success "Semitexa environment restarted!"
    printf "\n"
}

# ═══════════════════════════════════════════════════════════════════════
cmd_list() {
    printf "\n%s%s Semitexa Framework %s— CLI Commands\n\n" "$C_BOLD" "$C_GREEN" "$C_CYAN"
    printf "%s%s Shell Commands (no PHP required):%s\n" "$C_BOLD" "$C_YELLOW" "$C_RESET"
    printf "  %-32s %s\n" "install"       "Run composer install inside Docker (no local PHP needed)"
    printf "  %-32s %s\n" "demo:install"  "Install semitexa/demo inside Docker"
    printf "  %-32s %s\n" "server:start"   "Start Semitexa environment (Docker Compose)"
    printf "  %-32s %s\n" "server:stop"    "Stop Semitexa environment"
    printf "  %-32s %s\n" "server:restart" "Restart Semitexa environment"
    printf "  %-32s %s\n" "local-router:init"       "Prepare shared local router workspace"
    printf "  %-32s %s\n" "local-router:start"      "Start shared local router"
    printf "  %-32s %s\n" "local-router:stop"       "Stop shared local router"
    printf "  %-32s %s\n" "local-router:restart"    "Restart shared local router"
    printf "  %-32s %s\n" "local-router:doctor"     "Inspect shared local router state"
    printf "  %-32s %s\n" "local-domain:mode [dns|hosts]" "Get or set shared local domain mode"
    printf "  %-32s %s\n" "local-domain:add <domain.test>" "Register shared local domain"
    printf "  %-32s %s\n" "local-domain:remove <domain.test>" "Remove shared local domain"
    printf "  %-32s %s\n" "local-domain:list"       "List shared local domains"
    printf "  %-32s %s\n" "self-test"             "Verify setup"
    printf "  %-32s %s\n" "list"                  "Show this help"

    printf "\n%s%s PHP Commands (proxied to app container):%s\n" "$C_BOLD" "$C_YELLOW" "$C_RESET"
    if is_app_running; then
        run_compose exec -T app php vendor/bin/semitexa list --raw 2>/dev/null | while IFS= read -r _line; do
            _cmd="$(echo "$_line" | awk '{print $1}')"; _desc="$(echo "$_line" | sed 's/^[^ ]* *//')"
            case "$_cmd" in server:start|server:stop|server:restart|list|"") continue ;; esac
            printf "  %-32s %s\n" "$_cmd" "$_desc"
        done
    else
        info "(Start the server first to see all PHP commands)"
    fi
    printf "\n"
}

cmd_self_test() {
    printf "\n%s%s Semitexa — Self Test %s\n\n" "$C_BOLD" "$C_CYAN" "$C_RESET"
    _ok=0 _warn=0 _fail=0
    if command -v docker >/dev/null 2>&1; then success "Docker: $(docker --version 2>/dev/null)"; _ok=$((_ok+1)); else error "Docker: not found"; _fail=$((_fail+1)); fi
    if has_compose; then success "Compose: $(docker compose version 2>/dev/null || docker-compose version 2>/dev/null)"; _ok=$((_ok+1)); else error "Compose: not found"; _fail=$((_fail+1)); fi
    for _f in docker-compose.yml Dockerfile server.php .env.default composer.json; do
        if [ -f "$PROJECT_ROOT/$_f" ]; then success "File: $_f"; _ok=$((_ok+1)); else
            error "File: $_f (missing)"; _fail=$((_fail+1))
        fi
    done
    if [ -f "$PROJECT_ROOT/.env.local" ]; then success "File: .env.local"; _ok=$((_ok+1)); else info "File: .env.local (optional, not present)"; fi
    if [ -f "$PROJECT_ROOT/.env" ]; then warn "File: .env (legacy compatibility file detected)"; _warn=$((_warn+1)); fi
    [ -f "$PROJECT_ROOT/vendor/bin/semitexa" ] && { success "File: vendor/bin/semitexa"; _ok=$((_ok+1)); } || { error "File: vendor/bin/semitexa (missing)"; _fail=$((_fail+1)); }
    _arch="$(uname -m 2>/dev/null || echo unknown)"
    case "$_arch" in x86_64|amd64) success "Arch: AMD64" ;; aarch64|arm64) success "Arch: ARM64" ;; *) warn "Arch: $_arch (untested)" ;; esac
    if is_app_running; then success "App container: running"; _ok=$((_ok+1)); else info "App container: not running"; fi
    printf "\n  Results: %s%d OK%s, %s%d Warn%s, %s%d Error%s\n\n" "$C_GREEN" "$_ok" "$C_RESET" "$C_YELLOW" "$_warn" "$C_RESET" "$C_RED" "$_fail" "$C_RESET"
    [ "$_fail" -gt 0 ] && exit 1; exit 0
}

cmd_install() {
    printf "\n%s%s Semitexa — Install Dependencies %s\n\n" "$C_BOLD" "$C_CYAN" "$C_RESET"
    if ! has_compose; then error "Docker Compose is required. Install Docker Desktop or docker-compose."; exit 1; fi
    if [ ! -f "$PROJECT_ROOT/Dockerfile" ]; then error "Dockerfile not found. Cannot build container for installation."; exit 1; fi
    if [ ! -f "$PROJECT_ROOT/composer.json" ]; then error "composer.json not found. Is this a Semitexa project?"; exit 1; fi
    if [ ! -f "$PROJECT_ROOT/.env.default" ]; then error ".env.default not found. This project is missing its Semitexa baseline configuration."; exit 1; fi
    info "Building Docker image and running composer install inside container..."
    info "(This may take a few minutes on the first run)\n"
    run_compose build app
    run_compose run --rm --no-deps --user "$(id -u):$(id -g)" app composer install --no-interaction --prefer-dist
    if [ $? -eq 0 ]; then printf "\n"; success "Dependencies installed successfully!"; info "Next: bin/semitexa server:start"
    else printf "\n"; error "Installation failed. Check the output above."; exit 1; fi
    printf "\n"
}

cmd_demo_install() {
    printf "\n%s%s Semitexa — Install Demo %s\n\n" "$C_BOLD" "$C_CYAN" "$C_RESET"
    if ! has_compose; then error "Docker Compose is required. Install Docker Desktop or docker-compose."; exit 1; fi
    if [ ! -f "$PROJECT_ROOT/Dockerfile" ]; then error "Dockerfile not found. Cannot build container for demo installation."; exit 1; fi
    if [ ! -f "$PROJECT_ROOT/composer.json" ]; then error "composer.json not found. Is this a Semitexa project?"; exit 1; fi
    if [ ! -f "$PROJECT_ROOT/.env.default" ]; then error ".env.default not found. This project is missing its Semitexa baseline configuration."; exit 1; fi
    info "Installing semitexa/demo via Composer inside Docker..."
    info "(This may take a few minutes on the first run)\n"
    run_compose build app
    run_compose run --rm --no-deps --user "$(id -u):$(id -g)" app composer config repositories.semitexa-demo vcs https://github.com/semitexa/semitexa-demo.git
    run_compose run --rm --no-deps --user "$(id -u):$(id -g)" app composer require semitexa/demo:* --no-interaction --prefer-dist
    if [ $? -eq 0 ]; then printf "\n"; success "Semitexa Demo installed (semitexa/demo)."; info "Start or restart the server to load the new routes."; info "Remove when done: composer remove semitexa/demo"
    else printf "\n"; error "Demo installation failed. Check the output above."; exit 1; fi
    printf "\n"
}

cmd_init() {
    if ! has_compose; then error "Docker is required. Install Docker Desktop."; exit 1; fi
    if [ ! -f "$PROJECT_ROOT/Dockerfile" ]; then error "Dockerfile not found."; exit 1; fi
    if [ ! -f "$PROJECT_ROOT/.env.default" ]; then
        if command -v php >/dev/null 2>&1 && [ -f "$PROJECT_ROOT/vendor/bin/semitexa" ]; then
            warn ".env.default not found. Falling back to local PHP so init can scaffold it."
            php "$PROJECT_ROOT/vendor/bin/semitexa" init "$@"
            return
        fi
        error ".env.default not found. Run init once with local PHP so the scaffold can create it."
        exit 1
    fi
    info "Running init via Docker..."
    run_compose run --rm --no-deps --user "$(id -u):$(id -g)" app php vendor/bin/semitexa init "$@"
}

cmd_proxy() {
    if command -v php >/dev/null 2>&1; then
        if [ -f "$PROJECT_ROOT/vendor/bin/semitexa" ]; then
            if is_app_running; then
                if [ -t 0 ] && [ -t 1 ]; then run_compose exec app php vendor/bin/semitexa "$@"; else run_compose exec -T app php vendor/bin/semitexa "$@"; fi
            elif has_compose; then
                if env_runtime_file_exists; then
                    warn "App container is not running."
                    info "Starting container to run command..."
                    run_compose up -d app
                    info "Waiting for app container to be ready..."
                    _attempt=1
                    _ready=0
                    while [ "$_attempt" -le 30 ]; do
                        if is_app_running; then
                            _ready=1
                            break
                        fi
                        _attempt=$((_attempt + 1))
                        sleep 1
                    done
                    if [ "$_ready" -ne 1 ]; then
                        error "App container failed to reach running state after 30 seconds."
                        exit 1
                    fi
                    if [ -t 0 ] && [ -t 1 ]; then run_compose exec app php vendor/bin/semitexa "$@"; else run_compose exec -T app php vendor/bin/semitexa "$@"; fi
                else
                    info "Running locally with PHP (no Semitexa env files for Docker)..."
                    php "$PROJECT_ROOT/vendor/bin/semitexa" "$@"
                fi
            else
                info "Running locally with PHP (Docker not available)..."
                php "$PROJECT_ROOT/vendor/bin/semitexa" "$@"
            fi
        else
            error "vendor/bin/semitexa not found. Run: bin/semitexa install"
            exit 1
        fi
    else
        if has_compose; then
            if is_app_running; then
                if [ -t 0 ] && [ -t 1 ]; then run_compose exec app php vendor/bin/semitexa "$@"; else run_compose exec -T app php vendor/bin/semitexa "$@"; fi
            else
                error "App container is not running."
                info "Start with: bin/semitexa server:start"
                exit 1
            fi
        else
            error "PHP is not available and Docker is not running."
            info "Either start Docker and run: bin/semitexa server:start"
            info "Or install PHP locally"
            exit 1
        fi
    fi
}

# ═══════════════════════════════════════════════════════════════════════
COMMAND="${1:-}"
[ -z "$COMMAND" ] && { cmd_list; exit 0; }
shift
case "$COMMAND" in
    server:start)    cmd_server_start "$@" ;;
    server:stop)     cmd_server_stop "$@" ;;
    server:restart)  _svc=""; while [ $# -gt 0 ]; do case "$1" in --service=*) _svc="${1#--service=}" ;; -s) shift; _svc="${1:-}" ;; *) _svc="$1" ;; esac; shift; done; cmd_server_restart "$_svc" ;;
    local-router:init) cmd_local_router_init "$@" ;;
    local-router:start) cmd_local_router_start "$@" ;;
    local-router:stop) cmd_local_router_stop "$@" ;;
    local-router:restart) cmd_local_router_restart "$@" ;;
    local-router:doctor) cmd_local_router_doctor "$@" ;;
    local-domain:mode) cmd_local_domain_mode "$@" ;;
    local-domain:add) cmd_local_domain_add "$@" ;;
    local-domain:remove) cmd_local_domain_remove "$@" ;;
    local-domain:list) cmd_local_domain_list "$@" ;;
    install)         cmd_install "$@" ;;
    demo:install)    cmd_demo_install "$@" ;;
    list|help|--help|-h) cmd_list "$@" ;;
    self-test)       cmd_self_test "$@" ;;
    init)            cmd_init "$@" ;;
    *)               cmd_proxy "$COMMAND" "$@" ;;
esac
