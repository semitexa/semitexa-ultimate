# Environment: dev, test, prod
APP_ENV=dev
APP_DEBUG=1
APP_NAME="Semitexa App"

# Swoole server
SWOOLE_HOST=0.0.0.0
SWOOLE_PORT={{ default_swoole_port }}
SWOOLE_WORKER_NUM=4
SWOOLE_MAX_REQUEST=10000
SWOOLE_MAX_COROUTINE=100000
SWOOLE_LOG_FILE=var/log/swoole.log
SWOOLE_LOG_LEVEL=1

# Swoole shared memory tables (allocated upfront: rows × max_bytes)
# Increase for high-load or large session payloads.
# SWOOLE_SESSION_TABLE_SIZE=4096
# SWOOLE_SESSION_MAX_BYTES=65535
# SWOOLE_SSE_WORKER_TABLE_SIZE=4096
# SWOOLE_SSE_DELIVER_TABLE_SIZE=8192
# SWOOLE_SSE_PAYLOAD_MAX_BYTES=65535

# Session (Swoole Table). Cookie name and lifetime in seconds.
# SESSION_COOKIE_NAME=semitexa_session
# SESSION_LIFETIME=3600

# CORS
CORS_ALLOW_ORIGIN=*
CORS_ALLOW_METHODS=GET, POST, PUT, DELETE, OPTIONS
CORS_ALLOW_HEADERS=Content-Type, Authorization
CORS_ALLOW_CREDENTIALS=false

# Theme
THEME=default
INJECT_HEAD=""
INJECT_BODY=""

# Enable the starter project's deferred SSR demo out of the box.
SSR_ISOMORPHIC_ENABLED=true
# Keep the Hello starter cards visibly deferred so the fresh install clearly
# demonstrates Semitexa's KISS streaming path.
HELLO_DEMO_DELAY=1
# Keep the demo deferred page visibly staggered so slot arrivals are easy to inspect.
DEMO_DEFERRED_DELAY=1

# Keep the deferred KISS stream available after the initial block delivery so
# authorized users can reuse the same connection for ongoing runtime features.
SSR_DEFERRED_PERSISTENT_SSE=true
SSR_DEFERRED_PERSISTENT_SSE_REQUIRE_AUTH=true

# Optional crawler hints for the auto-generated robots.txt fallback.
# ROBOTS_SITEMAP_URL=https://example.com/sitemap.xml
# ROBOTS_HOST=example.com
# AI_SITEMAP_URL=https://example.com/sitemap.json

# Events: 1 = RabbitMQ (use with Docker), 0 = in-memory
# Uncomment host values only for non-Docker runs. In Docker, bin/semitexa
# server:start enables the matching overlay and rewrites hosts to service names.
# EVENTS_ASYNC=0
# RABBITMQ_HOST=127.0.0.1
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest
# RABBITMQ_VHOST=/

# Database (ORM) — uncomment to enable MySQL container on server:start
# For Docker, docker-compose.mysql.yml rewrites DB_HOST to the mysql service.
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=semitexa
# DB_USERNAME=root
# DB_PASSWORD=
# DB_POOL_SIZE=10
# DB_CHARSET=utf8mb4

# Database (ORM) — SQLite (no Docker container needed, file-based)
# DB_DRIVER=sqlite
# DB_SQLITE_PATH=var/database/semitexa.sqlite

# Database (ORM) — SQLite in-memory (testing only, data lost on restart)
# DB_DRIVER=sqlite
# DB_SQLITE_MEMORY=1

# Redis — uncomment to enable Redis container on server:start
# For Docker, docker-compose.redis.yml rewrites REDIS_HOST to the redis service.
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────
# LLM (AI) — three modes: disabled (default), local Ollama, or remote Ollama.
#
# The local Ollama Docker container (docker-compose.ollama.yml) starts ONLY
# when LLM_PROVIDER=ollama is uncommented below. Otherwise the container is
# skipped to save RAM and CPU.
#
# Mode 1 — Disabled (default)
#   Leave everything commented. No LLM features are available.
#
# Mode 2 — Local Ollama (runs ollama/ollama:latest in Docker)
#   Uncomment LLM_PROVIDER, LLM_BASE_URL, LLM_MODEL, LLM_TIMEOUT.
#   After server:start, pull a model inside the container:
#     docker compose exec ollama ollama pull gemma3:4b
#   Available models: gemma3:4b (~3 GB), gemma3:12b (~8 GB),
#     llama3.2:3b (~2 GB), llama3.2:8b (~5 GB), mistral:7b (~4 GB),
#     phi4:14b (~9 GB).
#
# Mode 3 — Remote Ollama (external Ollama instance, NO local Docker container)
#   Uncomment LLM_BACKEND=remote_ollama and the LLM_REMOTE_* variables.
#   The local ollama/ollama container will NOT start, saving significant RAM.
#   Point LLM_REMOTE_OLLAMA_URL to any reachable Ollama server (LAN, VPS, etc.).
# ─────────────────────────────────────────────────────────────────────────────

# --- Mode 2: Local Ollama (Docker) ---
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://ollama:11434
# LLM_MODEL=gemma3:4b
# LLM_TIMEOUT=60

# --- Mode 3: Remote Ollama (external server, no local container) ---
# LLM_BACKEND=remote_ollama
# LLM_REMOTE_OLLAMA_URL=http://your-ollama-server:11434
# LLM_REMOTE_OLLAMA_MODEL=gemma3:4b
# LLM_REMOTE_OLLAMA_TIMEOUT=120
# LLM_REMOTE_OLLAMA_RETRIES=2

# ─────────────────────────────────────────────────────────────────────────────
# NATS Event Ledger (semitexa-ledger)
#
# Enables cross-node event propagation via NATS JetStream + a local SQLite
# append-only ledger per node. Required for multi-node deployments.
#
# LEDGER_NODE_ID   — unique identifier for this node (e.g. "store-a", "node-1").
#                    Must be distinct across every process in the cluster.
# LEDGER_HMAC_KEY  — secret used to HMAC-sign each ledger entry for tamper
#                    evidence. Use a long random string (32+ chars). Must be
#                    the same value on every node in the cluster.
# LEDGER_DB_PATH   — path to the per-node SQLite ledger file.
#                    Defaults to /var/lib/semitexa/ledger/{node_id}.sqlite
#
# NATS_PRIMARY_URL     — primary NATS server with JetStream enabled.
#                        Also accepted as NATS_URL.
# NATS_SECONDARY_URL   — optional second NATS cluster for HA failover.
#                        When set, each node publishes to primary first and
#                        falls back to secondary; both are consumed for
#                        split-brain convergence.
#
# Dual-write migration (RabbitMQ → NATS phase 1):
#   EVENTS_DUAL_PRIMARY=rabbitmq   — existing transport that receives writes
#   EVENTS_DUAL_SECONDARY=nats     — NATS receives a shadow copy
#   Set EVENTS_TRANSPORT=dual to activate. Remove both once fully migrated.
# ─────────────────────────────────────────────────────────────────────────────

# LEDGER_NODE_ID=node-1
# LEDGER_HMAC_KEY=change-me-use-a-long-random-secret
# LEDGER_DB_PATH=var/ledger/node-1.sqlite

# NATS_PRIMARY_URL=nats://127.0.0.1:4222
# NATS_SECONDARY_URL=nats://127.0.0.1:4223

# --- Dual-write migration mode (RabbitMQ → NATS) ---
# EVENTS_DUAL_PRIMARY=rabbitmq
# EVENTS_DUAL_SECONDARY=nats
