{
    "name": "semitexa/ultimate",
    "description": "Semitexa Ultimate - full-stack project skeleton for SSR applications with docs and core modules",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Registry\\": "src/registry/",
            "Semitexa\\Ultimate\\": "src/"
        },
        "exclude-from-classmap": [
            "/src/modules/"
        ]
    },
    "require": {
        "php": "^8.4",
        "semitexa/core": "2026.05.08.1158",
        "semitexa/update": "2026.05.08.1158",
        "semitexa/docs": "2026.05.08.1158",
        "semitexa/auth": "2026.05.08.1158",
        "semitexa/authorization": "2026.05.08.1158",
        "semitexa/rbac": "2026.05.08.1158",
        "semitexa/api": "2026.05.08.1158",
        "semitexa/webhooks": "2026.05.08.1158",
        "semitexa/workflow": "2026.05.08.1158",
        "semitexa/cache": "2026.05.08.1158",
        "semitexa/storage": "2026.05.08.1158",
        "semitexa/ssr": "2026.05.08.1158",
        "semitexa/dev": "2026.05.08.1158",
        "semitexa/tenancy": "2026.05.08.1158",
        "semitexa/locale": "2026.05.08.1158",
        "semitexa/orm": "2026.05.08.1158",
        "semitexa/search": "2026.05.08.1158",
        "semitexa/mail": "2026.05.08.1158",
        "semitexa/media": "2026.05.08.1158",
        "semitexa/llm": "2026.05.08.1158",
        "semitexa/scheduler": "2026.05.08.1158",
        "semitexa/ledger": "2026.05.08.1158",
        "semitexa/project-graph": "2026.05.08.1158",
        "semitexa/theme": "2026.05.08.1158"
    },
    "require-dev": {
        "semitexa/testing": "2026.05.08.1158"
    },
    "keywords": [
        "semitexa",
        "ultimate",
        "project-skeleton",
        "ssr",
        "twig",
        "frontend",
        "starter-kit"
    ],
    "version": "v2.0.9"
}
